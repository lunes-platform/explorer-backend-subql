# Lunes Explorer API - Environment Variables
# Copy this file to .env and fill in your values

# Server
API_PORT=4000

# CORS (comma-separated allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:5175,http://localhost:3000

# RPC Connection
RPC_URL=wss://ws.lunes.io

# SubQuery Indexer GraphQL URL
INDEXER_URL=http://localhost:3000

# Public API URL (used for upload URLs returned to clients)
API_PUBLIC_URL=http://localhost:4000

# Admin Security (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ADMIN_SALT=change-me-generate-a-random-hex-string
ADMIN_TOKEN_SECRET=change-me-generate-a-random-hex-string
ADMIN_DEFAULT_PASSWORD=change-me-use-a-strong-password
