# Lunes Explorer Frontend - Environment Variables
# Copy this file to .env and fill in your values

# REST API URL (Express backend)
VITE_API_URL=http://localhost:4000

# SubQuery Indexer GraphQL URL
VITE_GRAPHQL_URL=http://localhost:3000

# WebSocket RPC endpoints (comma-separated)
VITE_WS_ENDPOINTS=wss://ws-archive.lunes.io,wss://ws-lunes-main-02.lunes.io,wss://ws-lunes-main-01.lunes.io
