# Lunes Explorer Backend Python - Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres
DB_PASSWORD=change-me

# Auth Security (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-generate-a-random-hex-string
ADMIN_DEFAULT_PASSWORD=change-me-use-a-strong-password
