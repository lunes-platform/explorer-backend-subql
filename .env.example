# ─── Explorer Lunes Backend — Environment Variables ───────────────────────────
# Copy this file to .env and fill in the values before running docker compose.
# NEVER commit .env to git.
#
# Gerar segredos:
#   openssl rand -base64 24                                                  # DB_PASSWORD
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" # JWT_SECRET

# ── PostgreSQL ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password

# ── Frontend (Vite build-time vars — baked into the JS bundle) ─────────────────
# Em produção, aponte para o domínio público (ex: https://api.explorer.lunes.io)
VITE_API_URL=http://localhost:4000
VITE_GRAPHQL_URL=http://localhost:3000
VITE_WS_ENDPOINTS=wss://ws-archive.lunes.io,wss://ws-lunes-main-02.lunes.io,wss://ws-lunes-main-01.lunes.io

# ── API (Node.js Express) ───────────────────────────────────────────────────────
# URL pública da API (usada em CORS e links)
API_PUBLIC_URL=http://localhost:4000

# ── Backend Python (FastAPI) ────────────────────────────────────────────────────
# DATABASE_URL é definida automaticamente pelo docker-compose usando DB_PASSWORD

# ── SubQuery ────────────────────────────────────────────────────────────────────
# Nenhuma variável extra necessária — usa DB_PASSWORD acima.
# startBlock está definido em project.yaml (atualmente 1).
# O indexer processa blocos sequencialmente a partir do startBlock.
