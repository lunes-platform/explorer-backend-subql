# ─── Explorer Lunes Backend — Environment Variables ───────────────────────────
# Copy this file to .env and fill in the values before running docker compose.
# NEVER commit .env to git.

# ── PostgreSQL ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password

# ── Frontend (Vite build-time vars — baked into the JS bundle) ─────────────────
# In production these point to your public domain/IP
VITE_API_URL=http://localhost:4000
VITE_GRAPHQL_URL=http://localhost:3000
VITE_WS_ENDPOINTS=wss://ws-archive.lunes.io,wss://ws-lunes-main-02.lunes.io,wss://ws-lunes-main-01.lunes.io

# ── API (Node.js Express) ───────────────────────────────────────────────────────
# JWT secret for admin endpoints
JWT_SECRET=change_me_jwt_secret
# CoinGecko or price API key (optional)
COINGECKO_API_KEY=

# ── Backend Python (FastAPI) ────────────────────────────────────────────────────
# Automatically set by docker-compose using DB_PASSWORD above
# DATABASE_URL=postgresql://postgres:${DB_PASSWORD}@postgres:5432/postgres

# ── SubQuery ────────────────────────────────────────────────────────────────────
# No extra vars needed — uses DB_PASSWORD above
# startBlock is set in project.yaml (currently 9400000)
